# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Telegram bot token
BOT_TOKEN=your_telegram_bot_token_here

# PostgreSQL
PG_HOST=postgres
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_postgres_password_here
PG_DB=ai_spam_bot

# Deployment
# SSH secrets are set via GitHub Actions secrets (SSH_HOST, SSH_USER, SSH_PRIVATE_KEY, SSH_PORT)
REMOTE_HOST= # deprecated - use GitHub Actions secrets
TELEGRAM_WEBHOOK_URL=https://ai-antispam.l1979.ru/process-tg-updates
REMOTE_USER= # deprecated - use GitHub Actions secrets

# Logging
LOGFIRE_TOKEN=your_logfire_token_here
LOGFIRE_READ_TOKEN=your_logfire_read_token_here

# MTProto Bridge
MTPROTO_HTTP_BASE_URL=https://tg-mcp.l1979.ru
MTPROTO_HTTP_BEARER_TOKEN=your_mtproto_bearer_token_here

# Custom Gateway
CUSTOM_GATEWAY_API_KEY=your_custom_gateway_api_key_here
CUSTOM_GATEWAY_MODEL=ai-antispam

API_BASE=https://ai-gateway.l1979.ru/v1
AI_GATEWAY_SSL_VERIFY=false

# GitHub Container Registry (for CI)
# GHCR_PULL_USER=your_ghcr_username
# GHCR_PULL_TOKEN=your_ghcr_pull_token